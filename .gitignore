# ---------------------------------------------------------------------------
01_data/index/.cache/
01_data/index/chunks.jsonl
01_data/index/chunks.jsonl.tmp
01_data/index/index.json
01_data/index/index.json.tmp
01_data/index/embeddings.npy
01_data/index/embeddings.npy.tmp
01_data/index/embeddings_ids.json
01_data/index/embeddings_ids.json.tmp
01_data/index/embeddings_meta.json
01_data/index/embeddings_meta.json.tmp
01_data/index/build.log

# Timestamped notion_sources backups (keep the live one)
01_data/notion_sources.backup_*.csv

# Build state / scratch dirs the agent uses
_build_state/

# ---------------------------------------------------------------------------
# OS / editor cruft
# ---------------------------------------------------------------------------
.DS_Store
Thumbs.db
*.swp
*.swo
.idea/
.vscode/

# ---------------------------------------------------------------------------
# Local working docs — personal planning notes that shouldn't be tracked.
# ---------------------------------------------------------------------------
WORK_PLAN.md
zzz_top

# ---------------------------------------------------------------------------
# Pipeline run artifacts — regenerated by scripts on every pass.
# Keep 01_data/ tracked (it holds canonical data products like
# notion_sources.csv and classifications.csv); 02_logs/ is pure run history.
# ---------------------------------------------------------------------------
02_logs/

# ---------------------------------------------------------------------------
# Claude Code tool state. Ignore everything under .claude/ except specs/
# which is intentionally versioned (PR #1 adds .claude/specs/add-ci/).
# Pattern note: must use `.claude/*` (matches contents) not `.claude/`
# (matches the dir itself) so that the !.claude/specs/ negation can take
# effect — git can't re-include files under an excluded directory.
# ---------------------------------------------------------------------------
.claude/*
!.claude/specs/
