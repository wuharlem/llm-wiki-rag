01_data/index/embeddings_meta.json
01_data/index/embeddings_meta.json.tmp
01_data/index/build.log

# Timestamped notion_sources backups (keep the live one)
01_data/notion_sources.backup_*.csv

# Build state / scratch dirs the agent uses
_build_state/

