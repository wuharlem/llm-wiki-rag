pytest-cache-files-*/
.coverage
.coverage.*
htmlcov/
.mypy_cache/
.ruff_cache/

# ---------------------------------------------------------------------------
# Built index artifacts (rebuildable from raw vault + scripts)
# manifest.csv is kept — small, useful for diffing what's indexed.
# ---------------------------------------------------------------------------
01_data/index/.cache/
01_data/index/chunks.jsonl
01_data/index/chunks.jsonl.tmp
01_data/index/index.json
01_data/index/index.json.tmp
01_data/index/embeddings.npy
01_data/index/embeddings.npy.tmp
01_data/index/embeddings_ids.json
01_data/index/embeddings_ids.json.tmp
01_data/index/embeddings_meta.json
01_data/index/embeddings_meta.json.tmp
01_data/index/build.log

# Timestamped notion_sources backups (keep the live one)
01_data/notion_sources.backup_*.csv

# Build state / scratch dirs the agent uses
_build_state/

# ---------------------------------------------------------------------------
# OS / editor cruft
# ---------------------------------------------------------------------------
.DS_Store
Thumbs.db
*.swp
*.swo
.idea/
.vscode/
# LibreOffice / OpenOffice lock files (created while a doc is open)
.~lock.*#
# Scratch permission-probe artifact
__perm_test
# Timestamped / suffixed notion_sources backups (keep the live one)
01_data/notion_sources.csv.bak-*
# One-off temp dirs staged for deletion
**/_tmp_delete_me/

# ---------------------------------------------------------------------------
# Local working docs — personal planning notes that shouldn't be tracked.
# ---------------------------------------------------------------------------
WORK_PLAN.md
CODE_AUDIT_2026-04-30.md
zzz_top

# ---------------------------------------------------------------------------
# Pipeline run artifacts — regenerated by scripts on every pass.
# Keep 01_data/ tracked (it holds canonical data products like
# notion_sources.csv and classifications.csv); 02_logs/ is pure run history.
# 03_notion_drafts/ holds generated Notion content; regeneratable from
# 01_data/notion_sources.csv via the per-folder/compact draft scripts.
# ---------------------------------------------------------------------------
02_logs/
03_notion_drafts/

# Intermediate URL-list artifacts in 00_inputs/. Only urls_dedup.csv is
# consumed by the pipeline (fetch.py, build_manifest.py); the others are
# one-time outputs from manual URL curation. Listing each file explicitly
# so a future input file under 00_inputs/ isn't accidentally ignored.
00_inputs/urls.csv
00_inputs/urls_already_in_folder.csv
00_inputs/urls_filtered.csv
00_inputs/urls_not_in_folder.csv
00_inputs/urls_removed.csv

# ---------------------------------------------------------------------------
# Claude Code tool state — including spec docs, which are useful while
# building a feature but don't need to live in the repo long-term.
# ---------------------------------------------------------------------------
.claude/
CLAUDE.md

# ---------------------------------------------------------------------------
# Skill definitions — user-personal (hardcode local vault paths and are
# consumed by the user's Claude sessions, not by repo cloners).
# ---------------------------------------------------------------------------
skills/

# ---------------------------------------------------------------------------
# Project-root _index/ — local artifacts written by save_query during
# development. Vault-side _index/ lives in the wiki, not this repo.
# ---------------------------------------------------------------------------
_index/

# ---------------------------------------------------------------------------
# Repo-root dumps from the people_directory analysis oneshots. Those scripts
# write to ../ (repo root), so ignore the patterns here too, not just in
# people_directory/.gitignore. The canonical home for these is
# people_directory/; see people_directory/WORKFLOW.md + CLAUDE.md §7.
# ---------------------------------------------------------------------------
# Date-anchored so new prefixes (clustering / clusters / network / hybrid /
# communities …) are all caught, but people.json / people_directory/ are not.
directory_analysis_*.html
people_*_20[0-9][0-9]-[0-9][0-9]-[0-9][0-9].html
people_*_20[0-9][0-9]-[0-9][0-9]-[0-9][0-9].csv

# ---------------------------------------------------------------------------
# Local pipeline state & backups (regeneratable / disposable).
# ---------------------------------------------------------------------------
01_data/index/source_state.json
*.bak_*

# ---------------------------------------------------------------------------
# directory-deploy/ — the public Cloudflare deploy of the People Directory is
# its own repository (github.com/wuharlem/ai-safety-directory), nested here for
# convenience but versioned independently. The main repo does not track it
# (also avoids accidentally committing a gitlink to the nested repo).
# ---------------------------------------------------------------------------
directory-deploy/
