# OS / editor cruft
# ---------------------------------------------------------------------------
.DS_Store
Thumbs.db
*.swp
*.swo
.idea/
.vscode/

# ---------------------------------------------------------------------------
# Local working docs — personal planning notes that shouldn't be tracked.
# ---------------------------------------------------------------------------
WORK_PLAN.md
CODE_AUDIT_2026-04-30.md
zzz_top

# ---------------------------------------------------------------------------
# Pipeline run artifacts — regenerated by scripts on every pass.
# Keep 01_data/ tracked (it holds canonical data products like
# notion_sources.csv and classifications.csv); 02_logs/ is pure run history.
# 03_notion_drafts/ holds generated Notion content; regeneratable from
# 01_data/notion_sources.csv via the per-folder/compact draft scripts.
# ---------------------------------------------------------------------------
02_logs/
03_notion_drafts/

# Intermediate URL-list artifacts in 00_inputs/. Only urls_dedup.csv is
# consumed by the pipeline (fetch.py, build_manifest.py); the others are
# one-time outputs from manual URL curation. Listing each file explicitly
# so a future input file under 00_inputs/ isn't accidentally ignored.
00_inputs/urls.csv
00_inputs/urls_already_in_folder.csv
00_inputs/urls_filtered.csv
00_inputs/urls_not_in_folder.csv
00_inputs/urls_removed.csv

# ---------------------------------------------------------------------------
# Claude Code tool state — including spec docs, which are useful while
# building a feature but don't need to live in the repo long-term.
# ---------------------------------------------------------------------------
.claude/
CLAUDE.md

# ---------------------------------------------------------------------------
# Skill caches (rebuildable; the SKILL.md itself stays tracked).
# ---------------------------------------------------------------------------
skills/**/.cache/
skills/**/__pycache__/
skills/**/*.cache.json

# ---------------------------------------------------------------------------
# Project-root _index/ — local artifacts written by save_query during
# development. Vault-side _index/ lives in the wiki, not this repo.
# ---------------------------------------------------------------------------
_index/
